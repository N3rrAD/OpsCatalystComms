TELEGRAM_BOT_TOKEN=1234567890:replace-with-token-from-botfather

# Telegram channel where broadcasts are posted. Use @channelusername or numeric chat id.
TELEGRAM_CHANNEL_ID=@your_tidehold_broadcast_channel

# Where admin alerts and button reports should be sent.
# This can be your private chat id or a facilitator admin group id.
ADMIN_ALERT_CHAT_ID=123456789

# Comma-separated Telegram numeric user ids allowed to use admin commands.
ADMIN_USER_IDS=123456789,987654321

# Event area coordinates and alert/watch radius.
# EVENT_BOUNDS watches a wider rectangular area, written as:
# south-west-lat,south-west-lon;north-east-lat,north-east-lon
EVENT_LAT=1.3024930556
EVENT_LON=103.8738305556
EVENT_BOUNDS=1.2990444444,103.8728305556;1.3059416667,103.8748305556
EVENT_WEATHER_RADIUS_KM=1
EVENT_LOCATION_LABEL=OCC Watch Area
LIGHTNING_RADIUS_KM=12

# Poll interval. Keep this >= 120 seconds for normal use.
WEATHER_POLL_SECONDS=120

# data.gov.sg endpoint. Lightning may require API access; keep configurable.
LIGHTNING_API_URL=https://api-open.data.gov.sg/v2/real-time/api/lightning
DATA_GOV_API_KEY=

# Used as a fallback when the Lightning Observation endpoint is unavailable.
TWO_HOUR_FORECAST_API_URL=https://api-open.data.gov.sg/v2/real-time/api/two-hr-forecast

# Fallback forecast endpoint used for /check_weather context.
FORECAST_API_URL=https://api-open.data.gov.sg/v2/real-time/api/twenty-four-hr-forecast

# Prevent repeated alerts while CAT1 remains active.
ALERT_COOLDOWN_MINUTES=20
CAT1_DEFAULT_DURATION_MINUTES=30

# Set to true to test Telegram flow without NEA/data.gov.sg.
DRY_RUN_WEATHER=false

# Vercel webhook/cron security. Use random strings.
TELEGRAM_WEBHOOK_SECRET=replace-with-random-webhook-secret
CRON_SECRET=replace-with-random-cron-secret
